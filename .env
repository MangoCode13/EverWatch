# Timezone (optional)
TZ=America/New_York

# Database
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=openemr
MYSQL_USER=openemr
MYSQL_PASSWORD=openemrpass

# OpenEMR initial admin (first-time init)
OPENEMR_ADMIN_USER=admin
OPENEMR_ADMIN_PASS=pass

# Ports on your host (Windows)
OPENEMR_HTTP_PORT=8080
OPENEMR_HTTPS_PORT=8443

# Elasticsearch security
ELASTIC_PASSWORD=CYSE587project!

# Kibana service account credential and encryption keys (required for alerting/actions)
KIBANA_SYSTEM_PASSWORD=ChangeThisKibanaSystemPassword
KIBANA_ENCRYPTEDSAVEDOBJECTS_KEY=ChangeThisTo32OrMoreCharsEncryptedSavedObjectsKey
KIBANA_SECURITY_SESSION_KEY=ChangeThisTo32OrMoreCharsSecuritySessionKey
KIBANA_REPORTING_KEY=ChangeThisTo32OrMoreCharsReportingKey

# Restrict outbound action connectors to trusted internal hosts only
KIBANA_ALLOWED_HOSTS=["smtp.internal.local","hooks.internal.local"]
