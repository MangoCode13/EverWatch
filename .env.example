# Copy this file to .env and fill in your own values before starting the stack.

# Timezone (optional)
TZ=America/New_York

# Database
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_DATABASE=openemr
MYSQL_USER=openemr
MYSQL_PASSWORD=change_me_db_password

# OpenEMR initial admin (first-time init)
OPENEMR_ADMIN_USER=admin
OPENEMR_ADMIN_PASS=change_me_admin_password

# Ports exposed on the host
OPENEMR_HTTP_PORT=8080
OPENEMR_HTTPS_PORT=8443

# Elasticsearch superuser password (min 8 chars, required complexity)
ELASTIC_PASSWORD=change_me_elastic_password

# Kibana service account and encryption keys
# Encryption keys must each be at least 32 characters long.
KIBANA_SYSTEM_PASSWORD=change_me_kibana_system_password
KIBANA_ENCRYPTEDSAVEDOBJECTS_KEY=change_me_32_or_more_chars_saved_objects_key
KIBANA_SECURITY_SESSION_KEY=change_me_32_or_more_chars_security_session_key
KIBANA_REPORTING_KEY=change_me_32_or_more_chars_reporting_key

# Restrict outbound action connectors to trusted internal hosts only
KIBANA_ALLOWED_HOSTS=["smtp.internal.local","hooks.internal.local"]
